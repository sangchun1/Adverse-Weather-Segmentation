# 베이스라인 설정
# Model: U-Net from scratch

seed: 42

data:
  root: "."
  split_dir: "data/splits"
  train_csv: "train.csv"
  val_csv: "val.csv"
  test_csv: "test.csv"

  input_width: 1024
  input_height: 512
  num_classes: 19
  ignore_index: 255

  # ImageNet normalization
  mean: [0.485, 0.456, 0.406]
  std: [0.229, 0.224, 0.225]

  class_names:
    - road
    - sidewalk
    - building
    - wall
    - fence
    - pole
    - traffic light
    - traffic sign
    - vegetation
    - terrain
    - sky
    - person
    - rider
    - car
    - truck
    - bus
    - train
    - motorcycle
    - bicycle

model:
  name: "unet"
  in_channels: 3
  num_classes: 19
  base_channels: 64

loss:
  name: "ce_focal_tversky" # ★ Dice를 Tversky로 전격 교체
  ce_weight: 1.0           # 전체 구조 지탱용 CE 비중
  dice_weight: 1.0         # Tversky 손실 함수 배율 (코드 내 변수 재활용)
  gamma: 1.0               # 하드 픽셀 완화 자극용 Focal 감마
  alpha: 0.3               # Tversky 오탐 페널티
  beta: 0.7                # ★ Tversky 미탐 페널티 (0점대 소수 클래스 복구용 무기)

optimizer:
  name: "adamw"
  lr: 0.001
  weight_decay: 0.0001

scheduler:
  name: "cosine_annealing"
  T_max: 50
  eta_min: 0.000001

train:
  epochs: 50
  batch_size: 8
  num_workers: 4
  pin_memory: true
  amp: true
  grad_clip_norm: null
  log_interval: 20
  val_interval: 1

augmentation:
  enabled: false
  name: "none"

enhancement:
  enabled: false
  name: "none"

checkpoint:
  save_dir: "outputs/checkpoints/unet_ce_focal_tversky" # 폴더명 변경
  save_best_name: "best_miou.pth"
  save_last_name: "last.pth"
  monitor: "val_miou"
  mode: "max"

early_stopping:
  enabled: true
  monitor: "val_miou"
  mode: "max"
  patience: 10
  min_delta: 0.0001

wandb:
  enabled: true
  project: "adverse-weather-segmentation"
  entity: null
  run_name: "unet_ce_focal_tversky" # 실험 런네임 변경
  tags:
    - baseline
    - unet
    - hybrid
    - tversky
  notes: "U-Net with CE (1.0) + Focal (gamma=1.0) + Tversky (a=0.3, b=0.7) to save tiny classes."
  dir: "outputs"

evaluate:
  batch_size: 8
  num_workers: 4
  save_predictions: true 
  output_dir: "outputs/checkpoints/unet_ce_focal_tversky"
